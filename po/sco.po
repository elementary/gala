#: data/gala.metainfo.xml.in:93
msgid "Improved HiDPI support"
msgstr "Impruive'd HiDPI support"

#: data/gala.metainfo.xml.in:70
msgid "Improve Reduced Motion behavior"
msgstr "Impruive Reduce'd Motion behaviour"

#: data/gala.metainfo.xml.in:94
msgid "Improved render performance"
msgstr "Impruive'd render performance"

#: data/gala.metainfo.xml.in:95
msgid "Reveal dock and panel in sync when starting"
msgstr ""

#: data/gala.metainfo.xml.in:96
msgid "Improved workspace switch dock animation"
msgstr "Impruive'd wirkspace switch dock animation"

#: data/gala.metainfo.xml.in:97
msgid "Picture-in-Picture windows now have rounded corners"
msgstr "Picter-in-Picter windas noo hae roondit corners"

#: data/gala.metainfo.xml.in:207
msgid "Window state is now saved on sleep and shutdown"
msgstr "Winda state is noo kept mind o on owerfaw an sneckdoon"

#: data/gala.metainfo.xml.in:208
msgid "Remove scaling effect from menus"
msgstr "Remuve scalin effect frae menus"

#: data/gala.metainfo.xml.in:209
msgid "Swipe up to close windows in Multitasking View"
msgstr ""

#: data/gala.metainfo.xml.in:240
msgid "Fixed rare crash when a dock window was killed"
msgstr "Fixt seldin crash when a dock winda was be-ended"

#: data/gala.metainfo.xml.in:241
msgid "Added interactive screenshot shortcut"
msgstr "Added interactive screenshot shortcut"

#: data/gala.metainfo.xml.in:242
msgid "Fixed crash when using tiling shortcuts"
msgstr "Fixt crash when usin tilin shortcuts"

#: data/gala.metainfo.xml.in:271
msgid "Improved shadows performance"
msgstr "Bettert performance o' shadas"

#: data/gala.metainfo.xml.in:315
msgid "Fix a potential crash when moving windows between workspaces"
msgstr "Fix a potential crash when muvin windas between werkspaces"

#: data/gala.metainfo.xml.in:316
msgid "Fix notification animation when entering multitasking view"
msgstr "Fix notificaition animaition when enterin the multitaskin view"

#: data/gala.metainfo.xml.in:331
msgid "Improve keyboard navigation in Multitasking View"
msgstr "Better the keybuird navigaition in Multitaskin View"

#: data/gala.metainfo.xml.in:332
msgid "Change panel color at the same time as wallpaper transition"
msgstr "Change panel coleur alang wi hintergroond transition"

#: data/gala.metainfo.xml.in:372
msgid ""
"Changing the wallpaper or going to sleep respects the \"Reduce Motion\" "
"option"
msgstr ""
"Changin the hintergroond or gaein tae sleep respects the \"Reduce Motion\" "
"option"

#: data/gala.metainfo.xml.in:373
msgid "Use appropriate drag-and-drop pointers when moving windows"
msgstr "Use appropriate click-an-drag pointers when muvin windas"

#: data/gala.metainfo.xml.in:374
msgid "Fix the issue when gestures in the multitasking view might stop working"
msgstr ""
"Fix the issue in the multitaskin view whar gestures micht nae langer werk"

#: data/gala.metainfo.xml.in:375
msgid "Improve dynamic workspaces behaviour with multiple monitors"
msgstr "Better the behaviour o' dynamic werkspaces wi multiple monitors"

#: data/gala.metainfo.xml.in:397
msgid "Improve handling of move-to-workspace shortcut"
msgstr "Better the handlin o' the muve-tae-werkspace shortcut"

